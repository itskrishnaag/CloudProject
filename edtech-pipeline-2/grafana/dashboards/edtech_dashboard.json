            "fillOpacity": 15,
            "thresholdsStyle": {
              "mode": "dashed+area"
            }
          }
        }
      },
      "alert": {
        "name": "Kafka Lag SLA Violation",
        "message": "Kafka consumer lag exceeded 10 000 \u2014 pipeline is falling behind",
        "conditions": [
          {
            "type": "query",
            "query": {
              "params": [
                "A",
                "5m",
                "now"
              ]
            },
            "reducer": {
              "type": "avg",
              "params": []
            },
            "evaluator": {
              "type": "gt",
              "params": [
                10000
              ]
            }
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "noDataState": "no_data"
      }
    },
